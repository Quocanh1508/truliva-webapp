generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


// ── Trạng thái xử lý webhook ──
enum WebhookStatus {
  PENDING
  PROCESSED
  FAILED
}

// ── Bảng lưu raw data từ Pancake (Step 3) ──
model WebhookRawEvent {
  id               String        @id @default(uuid())
  externalEventId  String?       @unique @map("external_event_id") // Idempotency key (Step 5)
  source           String        @default("pancake")
  eventType        String        @map("event_type")                // e.g. order_created, customer_updated
  payload          Json                                              // JSONB raw payload
  receivedAt       DateTime      @default(now()) @map("received_at")
  status           WebhookStatus @default(PENDING)
  errorLog         String?       @map("error_log")
  processingTimeMs Int?          @map("processing_time_ms")         // Response time tracking (Step 6)

  @@map("webhook_raw_events")
}

// ══════════════════════════════════════
//  PHASE 2: Business Models
// ══════════════════════════════════════

// ── Khách hàng ──
model Customer {
  id                  String    @id @default(uuid())
  pancakeCustomerId   String?   @unique @map("pancake_customer_id") // ID từ Pancake
  fullName            String    @map("full_name")
  phoneNumber         String?   @map("phone_number")
  email               String?
  address             String?
  fullAddress         String?   @map("full_address")
  provinceId          String?   @map("province_id")
  districtId          String?   @map("district_id")
  communeId           String?   @map("commune_id")
  provinceName        String?   @map("province_name")
  districtName        String?   @map("district_name")
  communeName         String?   @map("commune_name")
  source              String?   // Nguồn khách: facebook, shopee, etc.
  rawData             Json?     @map("raw_data")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  // Relations
  orders              Order[]

  @@map("customers")
}

// ── Đơn hàng ──
model Order {
  id                  String    @id @default(uuid())
  pancakeOrderId      Int       @unique @map("pancake_order_id")  // system_id từ Pancake
  customerId          String?   @map("customer_id")
  statusCode          Int?      @map("status_code")               // 0=pending, 1=confirmed, 2=shipping, 3=delivered, -1=cancelled
  statusName          String?   @map("status_name")               // delivered, pending, cancelled...
  totalPrice          Float?    @map("total_price")
  shippingFee         Float?    @map("shipping_fee")
  totalDiscount       Float?    @map("total_discount")
  totalQuantity       Int?      @map("total_quantity")
  moneyToCollect      Float?    @map("money_to_collect")          // Tiền thu hộ (COD)
  orderSource         String?   @map("order_source")              // Shopee, Facebook, Lazada...
  orderSourceId       String?   @map("order_source_id")           // marketplace_id
  orderLink           String?   @map("order_link")                // Link xem đơn trên Pancake
  shippingAddress     Json?     @map("shipping_address")          // Địa chỉ giao hàng đầy đủ
  warehouseInfo       Json?     @map("warehouse_info")            // Thông tin kho
  billFullName        String?   @map("bill_full_name")
  billPhoneNumber     String?   @map("bill_phone_number")
  note                String?
  partnerFee          Float?    @map("partner_fee")               // Phí vận chuyển đối tác
  feeMarketplace      Float?    @map("fee_marketplace")           // Phí sàn TMĐT
  pancakeCreatedAt    DateTime? @map("pancake_created_at")        // inserted_at từ Pancake
  pancakeUpdatedAt    DateTime? @map("pancake_updated_at")        // updated_at từ Pancake
  appointmentTime     DateTime? @map("appointment_time")          // Thời gian hẹn khách
  adminStatus         String?   @map("admin_status")              // Trạng thái đơn do Admin quản lý
  assignedKtvId       String?   @map("assigned_ktv_id")           // KTV được phân công
  // ── Trường mới theo Truliva Flow ──
  workType            String?   @map("work_type")                 // Loại công việc: giao_hang, lap_dat, bao_hanh...
  serviceType         String?   @map("service_type")              // Loại dịch vụ (tương ứng loại CV)
  mainStationId       String?   @map("main_station_id")           // Trạm chính được gán
  techStationId       String?   @map("tech_station_id")           // Trạm kỹ thuật được gán
  rescheduleReason    String?   @map("reschedule_reason")         // Lý do hẹn lại
  cancelReason        String?   @map("cancel_reason")             // Lý do hủy
  rawData             Json?     @map("raw_data")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  // Relations
  customer            Customer?     @relation(fields: [customerId], references: [id])
  items               OrderItem[]
  assignedKtv         User?         @relation(fields: [assignedKtvId], references: [id])
  mainStation         MainStation?  @relation(fields: [mainStationId], references: [id])
  techStation         TechStation?  @relation(fields: [techStationId], references: [id])
  serviceReports      ServiceReport[]

  @@map("orders")
}

// ── Chi tiết sản phẩm trong đơn ──
model OrderItem {
  id                  String    @id @default(uuid())
  orderId             String    @map("order_id")
  productName         String?   @map("product_name")
  sku                 String?
  quantity            Int?      @default(1)
  price               Float?
  discount            Float?    @default(0)
  variationInfo       Json?     @map("variation_info")            // Phân loại: size, màu...
  rawData             Json?     @map("raw_data")
  createdAt           DateTime  @default(now()) @map("created_at")

  // Relations
  order               Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

// ── Danh mục sản phẩm (Product Catalog) ──
model Product {
  id                  String    @id @default(uuid())
  pancakeProductId    String?   @unique @map("pancake_product_id") // ID sản phẩm từ Pancake
  sku                 String?   // Mã SP (ví dụ: 21141212)
  name                String    // Tên sản phẩm
  category            String?   // Danh mục (Device, Filter, etc.)
  imageUrl            String?   @map("image_url")
  costPrice           Float?    @map("cost_price")                 // Giá nhập cuối
  sellingPrice        Float?    @map("selling_price")               // Giá bán
  availableStock      Int?      @map("available_stock")             // Có thể bán
  totalImported       Int?      @map("total_imported")              // Tổng nhập
  totalStock          Int?      @map("total_stock")                 // Tổng tồn kho
  isActive            Boolean   @default(true) @map("is_active")
  variations          Json?     // Phân loại (size, màu, v.v.)
  rawData             Json?     @map("raw_data")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@map("products")
}

// ══════════════════════════════════════
//  PHASE 3: KTV Webapp Models
// ══════════════════════════════════════

// ── Trạm chính ──
model MainStation {
  id            String        @id @default(uuid())
  name          String        @unique
  isActive      Boolean       @default(true) @map("is_active")
  createdAt     DateTime      @default(now()) @map("created_at")

  // Relations
  techStations  TechStation[]
  orders        Order[]

  @@map("main_stations")
}

// ── Trạm kỹ thuật ──
model TechStation {
  id              String      @id @default(uuid())
  name            String
  mainStationId   String      @map("main_station_id")
  isActive        Boolean     @default(true) @map("is_active")
  createdAt       DateTime    @default(now()) @map("created_at")

  // Relations
  mainStation     MainStation @relation(fields: [mainStationId], references: [id])
  users           User[]
  orders          Order[]

  @@map("tech_stations")
}

enum UserRole {
  KTV
  ADMIN
  DEV
}

// ── Tài khoản người dùng (KTV + Admin) ──
model User {
  id              String       @id @default(uuid())
  username        String       @unique
  passwordHash    String       @map("password_hash")
  fullName        String       @map("full_name")
  role            UserRole     @default(KTV)
  phoneNumber     String?      @map("phone_number")
  techStationId   String?      @map("tech_station_id")  // KTV thuộc trạm kỹ thuật nào
  isActive        Boolean      @default(true) @map("is_active")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  // Relations
  serviceReports  ServiceReport[]
  assignedOrders  Order[]
  techStation     TechStation?  @relation(fields: [techStationId], references: [id])
  feedbacks       Feedback[]
  notifications   Notification[]

  @@map("users")
}

// ── Lịch sử thay đổi (Audit Log) ──
model AuditLog {
  id          String   @id @default(uuid())
  entityType  String   @map("entity_type")   // "Order"
  entityId    String   @map("entity_id")     // ID đơn hàng
  action      String                         // "created", "updated", "cancelled", "assigned", "restored"
  changes     Json?                          // { field, from, to }
  userId      String   @map("user_id")
  userName    String   @map("user_name")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

// ── Báo cáo hoàn thành ca KTV ──
model ServiceReport {
  id                String    @id @default(uuid())
  month             String                                // Tháng báo cáo (VD: "5/2026")
  ktvUserId         String    @map("ktv_user_id")         // FK → User
  customerName      String    @map("customer_name")
  customerPhone     String    @map("customer_phone")
  province          String                                // Tỉnh/Thành phố
  products          String[]                              // Mảng sản phẩm (multi-select)
  serviceType       String    @map("service_type")        // Loại dịch vụ
  imageUrls         String[]  @map("image_urls")          // URLs ảnh (Cloudinary)
  notes             String?                               // Ghi chú
  serialNumber      String?   @map("serial_number")       // Số serial
  distanceKm        Float?    @map("distance_km")         // Khoảng cách (km)
  isPaid            Boolean   @default(false) @map("is_paid")    // Đã trả tiền công
  serviceCost       Float?    @map("service_cost")        // Chi phí dịch vụ (legacy)
  additionalCost    Float?    @map("additional_cost")     // Chi phí phát sinh (legacy)
  orderId           String?   @map("order_id")            // Đơn hàng liên kết

  // ── Trường mới theo loại công việc ──
  workType          String?   @map("work_type")            // Loại công việc: Giao hàng, Lắp đặt, Thay lõi lọc, ...
  address           String?                                // Địa chỉ chi tiết
  actualAmount      Float?    @map("actual_amount")        // Tiền thu thực tế (thay serviceCost+additionalCost)
  waterSource       String?   @map("water_source")         // Nguồn nước: Nước máy trực tiếp, Nước máy bồn, Nước giếng, Nước mưa
  tdsIn             Float?    @map("tds_in")               // TDS đầu vào (ppm)
  tdsOut            Float?    @map("tds_out")              // TDS đầu ra (ppm)
  waterPressure     Float?    @map("water_pressure")       // Áp suất nước đầu vào (psi)
  spareParts        String[]  @map("spare_parts")          // Linh kiện phát sinh (multi-select)
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  ktvUser           User      @relation(fields: [ktvUserId], references: [id])
  order             Order?    @relation(fields: [orderId], references: [id])

  @@map("service_reports")
}

// ── Ảnh mẫu theo loại công việc và nhãn slot ──
model WorkTypeSampleImage {
  id          String   @id @default(uuid())
  workType    String   @map("work_type")
  slotLabel   String   @map("slot_label") // Ví dụ: "Ảnh seri sản phẩm"
  imageUrl    String   @map("image_url")   // Đường dẫn ảnh mẫu từ Cloudinary
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([workType, slotLabel])
  @@map("work_type_sample_images")
}

// ── Đóng góp ý kiến (Bug report / Feedback) ──
model Feedback {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  content     String   @db.Text
  imageUrls   String[] @map("image_urls")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("feedbacks")
}

// ── Thông báo người dùng (KTV) ──
model Notification {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  title       String
  content     String   @db.Text
  isRead      Boolean  @default(false) @map("is_read")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

