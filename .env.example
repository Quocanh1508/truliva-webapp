# ==============================================================================
# TRULIVA - Environment Variables Template
# ==============================================================================
# Copy this file to `.env` in the root directory and fill in the values.
# WARNING: Do NOT commit your actual `.env` file to Git.
# ==============================================================================

# --- SERVER CONFIGURATION ---
PORT=3000
NODE_ENV=development

# --- DATABASE (PostgreSQL) ---
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=verify-full
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=verify-full

# --- SECURITY & AUTHENTICATION ---
# JWT Secret key for user sessions signing (minimum 32 characters)
JWT_SECRET=your-strong-random-jwt-secret-minimum-32-chars
# Secret key to verify incoming webhooks from Pancake POS
PANCAKE_WEBHOOK_SECRET=your-strong-webhook-secret

# --- PANCAKE POS INTEGRATION ---
# API Key from Pancake POS dashboard to fetch orders and sync inventory
PANCAKE_API_KEY=your-pancake-api-key

# --- CLOUDINARY (Image Storage for Field Reports) ---
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# --- EMAIL SMTP (Gmail app passwords recommended) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASS=xxxx-xxxx-xxxx-xxxx
SMTP_FROM_NAME=Truliva System
# Public URL of the web application (used for password reset links)
APP_URL=http://localhost:5173

# --- WEB PUSH (PWA Browser Notifications) ---
VAPID_PUBLIC_KEY=your-vapid-public-key-base64url
VAPID_PRIVATE_KEY=your-vapid-private-key-base64url
VAPID_SUBJECT=mailto:your-email@gmail.com

# --- FIREBASE CLOUD MESSAGING (Android App Push Notifications) ---
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the full service account private key string, keeping \n characters
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT_HERE\n-----END PRIVATE KEY-----\n
