# ==============================================================================
# TRULIVA - Environment Variables Configuration
# ==============================================================================
# Sao chép file này thành `.env` ở thư mục gốc và điền đầy đủ giá trị.
# CẢNH BÁO: Không commit file `.env` thật lên Git. File này chỉ là template mẫu.
#
# ⚠️ QUAN TRỌNG KHI DEPLOY LÊN RENDER / CLOUD:
#    Khi nhập giá trị vào ô "Environment Variables" trên Dashboard của các dịch vụ
#    cloud (Render, Railway, Heroku...), KHÔNG bao giá trị trong dấu nháy kép "".
#    Render đọc nguyên văn ký tự nhập vào. Dấu nháy kép thừa sẽ làm crash server.
# ==============================================================================


# ------------------------------------------------------------------------------
# SERVER CONFIGURATION
# ------------------------------------------------------------------------------

# Cổng server lắng nghe yêu cầu. Render sẽ tự gán cổng qua biến này (thường là 10000).
# Khi chạy local, để mặc định là 3000.
PORT=3000

# Môi trường chạy: "development" (local) hoặc "production" (server triển khai).
# Ảnh hưởng đến cookie secure flag, log level, và CORS policy.
NODE_ENV=development


# ------------------------------------------------------------------------------
# DATABASE - PostgreSQL (Neon Cloud)
# ------------------------------------------------------------------------------

# Chuỗi kết nối PostgreSQL. Lấy từ Dashboard của Neon Cloud (neon.tech):
#   Project > Connection Details > Connection String.
# Định dạng: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
# ⚠️ KHÔNG bọc chuỗi này trong dấu "" khi điền lên Render.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require


# ------------------------------------------------------------------------------
# SECURITY & AUTHENTICATION
# ------------------------------------------------------------------------------

# Khóa bí mật ký JWT token cho phiên đăng nhập của người dùng.
# Sử dụng một chuỗi ngẫu nhiên dài ít nhất 32 ký tự.
# Tạo nhanh bằng: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-strong-random-jwt-secret-minimum-32-chars

# Khóa bí mật xác thực Webhook gửi từ Pancake POS.
# Pancake sẽ gửi giá trị này trong query string: /webhooks/pancake?secret=...
# Điền giống với giá trị bạn cấu hình trên trang Pancake POS Webhook Settings.
PANCAKE_WEBHOOK_SECRET=your-strong-webhook-secret


# ------------------------------------------------------------------------------
# PANCAKE POS INTEGRATION
# ------------------------------------------------------------------------------

# API Key của tài khoản Pancake POS dùng để gọi API đồng bộ đơn hàng và kho.
# Lấy tại: Pancake POS Dashboard > Cài đặt > API > API Key.
PANCAKE_API_KEY=your-pancake-api-key


# ------------------------------------------------------------------------------
# CLOUDINARY - Image Storage (Ảnh nghiệm thu của KTV)
# ------------------------------------------------------------------------------

# Thông tin xác thực Cloudinary để upload ảnh nghiệm thu từ KTV.
# Lấy tại: https://console.cloudinary.com > Dashboard > API Keys.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret


# ------------------------------------------------------------------------------
# EMAIL - SMTP (Gửi email đặt lại mật khẩu)
# ------------------------------------------------------------------------------

# Host SMTP. Để dùng Gmail, giữ nguyên giá trị bên dưới.
SMTP_HOST=smtp.gmail.com

# Cổng SMTP. 587 dùng cho STARTTLS (khuyến nghị với Gmail).
SMTP_PORT=587

# Đặt "false" khi dùng cổng 587 (STARTTLS). Đặt "true" nếu dùng cổng 465 (SSL).
SMTP_SECURE=false

# Địa chỉ email Gmail dùng để gửi thư.
SMTP_USER=your-gmail-address@gmail.com

# Mật khẩu ứng dụng (App Password) 16 ký tự của Gmail.
# KHÔNG dùng mật khẩu đăng nhập Gmail thông thường.
# Tạo tại: Google Account > Security > 2-Step Verification > App Passwords.
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# Tên hiển thị của địa chỉ gửi thư trong hộp thư người nhận.
SMTP_FROM_NAME=Truliva System

# URL công khai của ứng dụng (dùng để tạo link đặt lại mật khẩu trong email).
# Khi chạy local: http://localhost:5173
# Khi deploy: https://truliva-ktv-webapp.onrender.com (hoặc domain thật của bạn)
APP_URL=http://localhost:5173


# ------------------------------------------------------------------------------
# WEB PUSH - PWA Push Notifications (Thông báo đẩy trình duyệt)
# ------------------------------------------------------------------------------

# VAPID Keys dùng để xác thực Web Push Notification (chuẩn RFC 8292).
# Tạo cặp key mới chạy: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k);"
# Sau khi tạo, KHÔNG thay đổi, vì KTV đã đăng ký subscription với public key cũ sẽ bị mất thông báo.
VAPID_PUBLIC_KEY=your-vapid-public-key-base64url
VAPID_PRIVATE_KEY=your-vapid-private-key-base64url

# Địa chỉ liên hệ kỹ thuật để Web Push Server có thể báo cáo vấn đề (bắt buộc).
VAPID_SUBJECT=mailto:your-email@gmail.com


# ------------------------------------------------------------------------------
# FIREBASE CLOUD MESSAGING - Native Push Notifications (Thông báo đẩy App Android)
# ------------------------------------------------------------------------------

# Thông tin Firebase Service Account dùng để gửi Push Notification qua FCM
# đến ứng dụng Android (Capacitor APK) của KTV.
# Lấy tại: Firebase Console > Project Settings > Service Accounts > Generate new private key.

# ID dự án Firebase. Ví dụ: "my-project-12345"
FIREBASE_PROJECT_ID=your-firebase-project-id

# Email của Service Account. Ví dụ: "firebase-adminsdk-xxxxx@project.iam.gserviceaccount.com"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Private Key của Service Account (chuỗi PEM nhiều dòng).
# Trong file JSON download từ Firebase, key này có tên "private_key".
# ⚠️ Khi điền lên Render: Sao chép TOÀN BỘ nội dung key bao gồm cả
#    "-----BEGIN PRIVATE KEY-----" và "-----END PRIVATE KEY-----",
#    KHÔNG bọc trong dấu nháy kép "", giữ nguyên ký tự \n ở trong chuỗi.
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT_HERE\n-----END PRIVATE KEY-----\n
