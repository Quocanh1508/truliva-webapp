# Server
PORT=3000
NODE_ENV=production

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Webhook Security (dùng làm query string: ?secret=xxx)
PANCAKE_WEBHOOK_SECRET="your-strong-production-secret"
JWT_SECRET="your-jwt-secret-key-change-me-in-production"

# Pancake API Key
PANCAKE_API_KEY="your-pancake-api-key"

# Cloudinary (upload ảnh KTV)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Email SMTP (Gmail)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE="false"
SMTP_USER="your-gmail-address@gmail.com"
SMTP_PASS="your-16-character-gmail-app-password"
SMTP_FROM_NAME="Truliva System"
APP_URL="http://localhost:5173"

